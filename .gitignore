# Build artifacts
/target/
**/target/

# Cargo.lock is tracked by default. The release workflow's
# `semantic-release-cargo` plugin updates it during version bumps and
# the `@semantic-release/git` plugin commits it back. For library
# crates that prefer not to track Cargo.lock, add `/Cargo.lock` below
# and drop it from the `assets` list in `.releaserc.json`.

# Coverage artifacts (cargo-llvm-cov)
*.profraw
*.profdata

# direnv / Nix
/.direnv/
/.envrc.local

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Node (commitlint, semantic-release)
/node_modules/

# Claude Code local config
/.claude/
